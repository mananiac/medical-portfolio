---
import Layout from '@layouts/Layout.astro';
---

<Layout title="About & Curriculum Vitae | Dr. Drishti Sagar, MD" activeNav="about & cv">
  <!-- Page Header -->
  <section class="py-12 bg-slate-100/70 border-b border-slate-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
        <div>
          <span class="text-xs font-bold text-medical-700 uppercase tracking-widest bg-medical-50 px-3 py-1 rounded-full border border-medical-200">
            Professional Profile
          </span>
          <h1 class="text-3xl sm:text-4xl font-extrabold text-slate-900 mt-2">Biography & Clinical Career</h1>
          <p class="text-slate-600 text-sm mt-1 max-w-2xl">
            Detailed overview of academic qualifications, MUHS MD Gold Medal distinction, hospital residency positions, and infection control leadership.
          </p>
        </div>

        <!-- Prominent Download CV CTA Button -->
        <div>
          <a
            href="/cv.pdf"
            download="Dr_Drishti_Sagar_MD_CV.pdf"
            class="inline-flex items-center gap-2 px-6 py-3.5 rounded-xl bg-primary-900 hover:bg-slate-800 text-white font-semibold text-sm shadow-md hover:shadow-lg transition-all"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-medical-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            Download Official CV (.PDF)
          </a>
        </div>
      </div>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-16">
    
    <!-- Executive Biography -->
    <section class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-start">
      <div class="lg:col-span-4">
        <div class="p-6 bg-white rounded-2xl border border-slate-200 shadow-sm space-y-4">
          <img
            src="/doctor_headshot.png"
            alt="Dr. Drishti Sagar portrait"
            class="w-full h-auto rounded-xl object-cover"
          />
          <div class="space-y-2 text-xs text-slate-600">
            <div class="flex justify-between py-1 border-b border-slate-100">
              <span class="font-medium">Current Position:</span>
              <span class="font-semibold text-slate-900">Senior Resident, Delhi Govt</span>
            </div>
            <div class="flex justify-between py-1 border-b border-slate-100">
              <span class="font-medium">Location:</span>
              <span class="font-semibold text-slate-900">New Delhi, India</span>
            </div>
            <div class="flex justify-between py-1">
              <span class="font-medium">Specialty:</span>
              <span class="font-semibold text-medical-700">Clinical Microbiology</span>
            </div>
          </div>
        </div>
      </div>

      <div class="lg:col-span-8 space-y-6">
        <h2 class="text-2xl font-bold text-slate-900">Executive Summary</h2>
        <div class="prose prose-slate max-w-none text-slate-600 space-y-4 text-base leading-relaxed">
          <p>
            <strong>Dr. Drishti Sagar, MD</strong>, is a distinguished Clinical Microbiologist, Gold Medalist (MUHS MD Examination Rank 1), Infection Prevention and Control Specialist, and Public Health enthusiast.
          </p>
          <p>
            Dr. Sagar completed her Doctor of Medicine (MD) in Clinical Microbiology and Infectious Diseases from Maharashtra University of Health Sciences (MUHS), earning the prestigious ICMR MD Thesis Grant and securing the 1st Rank across the university. She also holds a Post Graduate Certificate in Health Economics, Healthcare Financing, and Policy from the Indian Institutes of Public Health (IIPHs).
          </p>
          <p>
            Her clinical experience spans premier medical institutions across India—including Senior Residency roles with the Delhi Government, GS Medical College & KEM Hospital (Mumbai), B J Government Medical College (Pune), and serving as Infection Control Officer at Aakash Healthcare Super Speciality Hospital (New Delhi). She is an active peer reviewer for the <em>Indian Journal of Medical Microbiology and Tropical Diseases (IJMMTD)</em> and the <em>Indian Journal of Medical Research (IJMR)</em>.
          </p>
        </div>
      </div>
    </section>

    <!-- Academic Education Timeline -->
    <section class="space-y-8">
      <div class="border-b border-slate-200 pb-4">
        <h2 class="text-2xl font-bold text-slate-900">Academic Education & Degrees</h2>
      </div>

      <div class="relative border-l-2 border-slate-200 ml-4 space-y-8 pl-6">
        
        <div class="relative group">
          <div class="absolute -left-[31px] top-1.5 w-4 h-4 rounded-full bg-amber-500 border-4 border-white"></div>
          <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-2xs space-y-1">
            <div class="flex items-center justify-between">
              <span class="text-xs font-bold text-amber-800 bg-amber-50 px-2.5 py-0.5 rounded border border-amber-200">
                2018 — 2021
              </span>
              <span class="text-xs font-extrabold text-amber-700 bg-amber-100 px-2 py-0.5 rounded">
                🥇 Rank 1 Gold Medalist
              </span>
            </div>
            <h3 class="text-lg font-bold text-slate-900">Doctor of Medicine (MD) in Clinical Microbiology & Infectious Diseases</h3>
            <p class="text-sm font-medium text-slate-600">Maharashtra University of Health Sciences (MUHS)</p>
            <p class="text-xs text-slate-500 mt-1">Recipient of prestigious ICMR MD Thesis Grant & MUHS MD Examination Gold Medal.</p>
          </div>
        </div>

        <div class="relative group">
          <div class="absolute -left-[31px] top-1.5 w-4 h-4 rounded-full bg-primary-900 border-4 border-white"></div>
          <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-2xs space-y-1">
            <span class="text-xs font-bold text-primary-800 bg-primary-50 px-2.5 py-0.5 rounded border border-primary-200">
              2023
            </span>
            <h3 class="text-lg font-bold text-slate-900">Post Graduate Program in Health Economics, Healthcare Financing & Policy</h3>
            <p class="text-sm font-medium text-slate-600">Indian Institutes of Public Health (IIPHs)</p>
          </div>
        </div>

        <div class="relative group">
          <div class="absolute -left-[31px] top-1.5 w-4 h-4 rounded-full bg-medical-600 border-4 border-white"></div>
          <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-2xs space-y-1">
            <span class="text-xs font-bold text-medical-700 bg-medical-50 px-2.5 py-0.5 rounded border border-medical-200">
              2012 — 2017
            </span>
            <h3 class="text-lg font-bold text-slate-900">Bachelor of Medicine, Bachelor of Surgery (MBBS)</h3>
            <p class="text-sm font-medium text-slate-600">Teerthanker Mahaveer University, Moradabad</p>
          </div>
        </div>

      </div>
    </section>

    <!-- Clinical Experience & Residency Timeline -->
    <section class="space-y-8">
      <div class="border-b border-slate-200 pb-4">
        <h2 class="text-2xl font-bold text-slate-900">Clinical Residency & Institutional Career</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        
        <div class="p-6 bg-white rounded-xl border border-slate-200 space-y-3">
          <div class="flex items-center justify-between">
            <span class="text-xs font-bold text-medical-700 bg-medical-50 px-2.5 py-1 rounded-md">
              Oct 2023 — Present
            </span>
            <span class="text-xs font-medium text-slate-500">New Delhi</span>
          </div>
          <h3 class="font-bold text-slate-900 text-lg">Senior Resident</h3>
          <p class="text-xs font-semibold text-slate-600">Delhi Government</p>
          <p class="text-xs text-slate-500 leading-relaxed">
            Diagnostic microbiology reporting, public health disease surveillance, and hospital infection control audits.
          </p>
        </div>

        <div class="p-6 bg-white rounded-xl border border-slate-200 space-y-3">
          <div class="flex items-center justify-between">
            <span class="text-xs font-bold text-primary-800 bg-primary-50 px-2.5 py-1 rounded-md">
              Feb 2023 — Sep 2023
            </span>
            <span class="text-xs font-medium text-slate-500">New Delhi</span>
          </div>
          <h3 class="font-bold text-slate-900 text-lg">Senior Resident & Infection Control Officer</h3>
          <p class="text-xs font-semibold text-slate-600">Aakash Healthcare Super Speciality Hospital</p>
          <p class="text-xs text-slate-500 leading-relaxed">
            Supervised Hospital Infection Control Committee (HICC) audits, ICU surveillance, and hospital safety protocols.
          </p>
        </div>

        <div class="p-6 bg-white rounded-xl border border-slate-200 space-y-3">
          <div class="flex items-center justify-between">
            <span class="text-xs font-bold text-indigo-800 bg-indigo-50 px-2.5 py-1 rounded-md">
              Oct 2021 — Aug 2022
            </span>
            <span class="text-xs font-medium text-slate-500">Mumbai</span>
          </div>
          <h3 class="font-bold text-slate-900 text-lg">Senior Resident</h3>
          <p class="text-xs font-semibold text-slate-600">GS Medical College & KEM Hospital, Mumbai</p>
          <p class="text-xs text-slate-500 leading-relaxed">
            Formulated SOPs for infectious disease testing, NABL ISO 15189 lab audits, and IDSP surveillance.
          </p>
        </div>

        <div class="p-6 bg-white rounded-xl border border-slate-200 space-y-3">
          <div class="flex items-center justify-between">
            <span class="text-xs font-bold text-emerald-800 bg-emerald-50 px-2.5 py-1 rounded-md">
              May 2018 — Jul 2021
            </span>
            <span class="text-xs font-medium text-slate-500">Pune</span>
          </div>
          <h3 class="font-bold text-slate-900 text-lg">Postgraduate & Senior Resident</h3>
          <p class="text-xs font-semibold text-slate-600">B J Government Medical College, Pune</p>
          <p class="text-xs text-slate-500 leading-relaxed">
            Molecular microbiology testing for COVID-19 emergency response, editor of 'Microflash' health magazine.
          </p>
        </div>

      </div>
    </section>

  </div>
</Layout>
