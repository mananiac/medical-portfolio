---
import Layout from '@layouts/Layout.astro';
---

<Layout title="Dr. Drishti Sagar, MD | Clinical Microbiologist & Infection Control Specialist" activeNav="home">
  <!-- Hero Section -->
  <section class="relative overflow-hidden py-16 lg:py-24 bg-gradient-to-b from-slate-50 via-slate-100/60 to-slate-50 border-b border-slate-200/80">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
        
        <!-- Left Text Content -->
        <div class="lg:col-span-7 space-y-6">
          <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full bg-medical-50 border border-medical-200 text-medical-800 text-xs font-semibold tracking-wide">
            <span class="w-2 h-2 rounded-full bg-medical-500 animate-pulse"></span>
            Clinical Microbiologist • MUHS MD Gold Medalist (Rank 1)
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-slate-900 tracking-tight leading-tight">
            Advancing <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-900 via-medical-700 to-medical-600">Clinical Microbiology</span> & Hospital Infection Control
          </h1>

          <blockquote class="italic text-medical-800 border-l-4 border-medical-500 pl-4 py-1 text-sm bg-medical-50/60 rounded-r-lg font-medium">
            "Happiness and bacteria have one thing in common; they multiply by dividing!!!"
          </blockquote>

          <p class="text-lg text-slate-600 leading-relaxed max-w-2xl">
            Welcome to the academic and professional portfolio of <strong>Dr. Drishti Sagar, MD</strong>. Specialized in diagnostic microbiology, hospital infection prevention, infectious disease surveillance, and public health policy.
          </p>

          <!-- Credential Badges -->
          <div class="flex flex-wrap gap-2 pt-1">
            <span class="px-3 py-1 bg-white border border-slate-200 text-amber-800 font-semibold rounded-lg text-xs shadow-2xs">
              🥇 Rank 1 MUHS MD Examination
            </span>
            <span class="px-3 py-1 bg-white border border-slate-200 text-emerald-800 font-semibold rounded-lg text-xs shadow-2xs">
              🔬 ICMR Thesis Grantee
            </span>
            <span class="px-3 py-1 bg-white border border-slate-200 text-slate-700 font-semibold rounded-lg text-xs shadow-2xs">
              🛡️ ISO 15189 Quality Auditor
            </span>
          </div>

          <!-- CTAs -->
          <div class="flex flex-wrap gap-4 pt-4">
            <a
              href="/about"
              class="px-6 py-3.5 rounded-xl bg-primary-900 text-white font-semibold text-sm shadow-md hover:bg-slate-800 hover:shadow-lg transition-all duration-150 inline-flex items-center gap-2"
            >
              Explore Biography & CV
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </a>
            <a
              href="/contact"
              class="px-6 py-3.5 rounded-xl bg-white text-slate-700 border border-slate-300 font-semibold text-sm shadow-sm hover:bg-slate-50 hover:border-slate-400 transition-all duration-150 inline-flex items-center gap-2"
            >
              Professional Contact
            </a>
          </div>
        </div>

        <!-- Right Headshot Image -->
        <div class="lg:col-span-5 flex justify-center">
          <div class="relative w-full max-w-sm sm:max-w-md group">
            <div class="absolute -inset-1.5 bg-gradient-to-r from-medical-600 to-primary-900 rounded-3xl blur opacity-25 group-hover:opacity-40 transition duration-300"></div>
            
            <div class="relative rounded-2xl overflow-hidden bg-white border border-slate-200 shadow-xl">
              <img
                src="/doctor_headshot.png"
                alt="Dr. Drishti Sagar, MD - Professional Portrait"
                class="w-full h-auto object-cover aspect-4/5"
                loading="eager"
              />
              <div class="p-4 bg-slate-900/90 backdrop-blur-md text-white border-t border-slate-800 flex items-center justify-between">
                <div>
                  <h2 class="font-heading font-bold text-sm">Dr. Drishti Sagar, MD</h2>
                  <p class="text-xs text-medical-300">Clinical Microbiologist & Senior Resident</p>
                </div>
                <span class="px-2.5 py-1 text-[10px] font-extrabold uppercase tracking-wider bg-amber-500 text-slate-950 rounded-md">
                  Gold Medalist
                </span>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Quick Impact Metrics -->
  <section class="py-10 bg-primary-900 text-white border-b border-slate-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div class="space-y-1">
          <div class="text-3xl sm:text-4xl font-extrabold text-medical-400 font-heading">15+</div>
          <div class="text-xs text-slate-300 font-medium uppercase tracking-wider">Indexed Publications</div>
        </div>
        <div class="space-y-1">
          <div class="text-3xl sm:text-4xl font-extrabold text-amber-400 font-heading">Rank 1</div>
          <div class="text-xs text-slate-300 font-medium uppercase tracking-wider">MUHS MD Examination</div>
        </div>
        <div class="space-y-1">
          <div class="text-3xl sm:text-4xl font-extrabold text-medical-400 font-heading">5+ Yrs</div>
          <div class="text-xs text-slate-300 font-medium uppercase tracking-wider">Residency & Hospital Care</div>
        </div>
        <div class="space-y-1">
          <div class="text-3xl sm:text-4xl font-extrabold text-medical-400 font-heading">2 Journals</div>
          <div class="text-xs text-slate-300 font-medium uppercase tracking-wider">Peer Reviewer (IJMMTD & IJMR)</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Core Expertise Section -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto space-y-4 mb-16">
        <span class="text-xs font-bold text-medical-700 uppercase tracking-widest bg-medical-50 px-3.5 py-1 rounded-full border border-medical-200">
          Core Domains
        </span>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-slate-900">Clinical & Public Health Expertise</h2>
        <p class="text-slate-600 text-base">
          Specialized in diagnostic microbiology testing, hospital infection control committee (HICC) audits, and disease surveillance.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        
        <!-- Expertise Card 1 -->
        <div class="p-6 rounded-2xl bg-slate-50 border border-slate-200/80 hover:shadow-medical-soft transition-all space-y-3">
          <div class="w-12 h-12 rounded-xl bg-medical-100 text-medical-700 flex items-center justify-center font-bold text-xl">
            🧫
          </div>
          <h3 class="text-lg font-bold text-slate-900">Clinical Microbiology</h3>
          <p class="text-slate-600 text-sm leading-relaxed">
            Diagnostic bacteriology, mycology, molecular testing, and antimicrobial susceptibility testing SOPs.
          </p>
        </div>

        <!-- Expertise Card 2 -->
        <div class="p-6 rounded-2xl bg-slate-50 border border-slate-200/80 hover:shadow-medical-soft transition-all space-y-3">
          <div class="w-12 h-12 rounded-xl bg-amber-100 text-amber-800 flex items-center justify-center font-bold text-xl">
            🛡️
          </div>
          <h3 class="text-lg font-bold text-slate-900">Infection Prevention & Control</h3>
          <p class="text-slate-600 text-sm leading-relaxed">
            Hospital Infection Control Officer, ICU surveillance, hand hygiene audits, and NABL ISO 15189 quality audits.
          </p>
        </div>

        <!-- Expertise Card 3 -->
        <div class="p-6 rounded-2xl bg-slate-50 border border-slate-200/80 hover:shadow-medical-soft transition-all space-y-3">
          <div class="w-12 h-12 rounded-xl bg-primary-100 text-primary-800 flex items-center justify-center font-bold text-xl">
            🌐
          </div>
          <h3 class="text-lg font-bold text-slate-900">Public Health & IDSP</h3>
          <p class="text-slate-600 text-sm leading-relaxed">
            Integrated Disease Surveillance Project (IDSP) reporting, COVID-19 outbreak response, and health economics.
          </p>
        </div>

        <!-- Expertise Card 4 -->
        <div class="p-6 rounded-2xl bg-slate-50 border border-slate-200/80 hover:shadow-medical-soft transition-all space-y-3">
          <div class="w-12 h-12 rounded-xl bg-emerald-100 text-emerald-800 flex items-center justify-center font-bold text-xl">
            📑
          </div>
          <h3 class="text-lg font-bold text-slate-900">Journal Review & Research</h3>
          <p class="text-slate-600 text-sm leading-relaxed">
            Peer reviewer for Indian Journal of Medical Microbiology & Research (IJMMTD, IJMR) and ICMR thesis research.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- CTA Banner Section -->
  <section class="py-16 bg-slate-900 text-white relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 flex flex-col md:flex-row items-center justify-between gap-8">
      <div class="space-y-2 max-w-2xl">
        <h2 class="text-2xl sm:text-3xl font-extrabold text-white">Seeking Infection Control Consultation or Academic Collaboration?</h2>
        <p class="text-slate-400 text-sm">Available for hospital infection control committee audits, diagnostic microbiology reviews, and public health research.</p>
      </div>
      <div class="flex gap-4">
        <a href="/contact" class="px-6 py-3.5 rounded-xl bg-medical-600 hover:bg-medical-500 text-white font-semibold text-sm transition-all shadow-md">
          Get in Touch
        </a>
        <a href="/media-kit" class="px-6 py-3.5 rounded-xl bg-slate-800 hover:bg-slate-700 text-slate-200 font-semibold text-sm transition-all">
          View Media Kit
        </a>
      </div>
    </div>
  </section>
</Layout>
