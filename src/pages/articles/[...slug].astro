---
import { getCollection, type CollectionEntry } from 'astro:content';
import Layout from '@layouts/Layout.astro';
import CitationGenerator from '@components/CitationGenerator.astro';
import Newsletter from '@components/Newsletter.astro';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

interface Props {
  article: CollectionEntry<'articles'>;
}

const { article } = Astro.props;
const { Content } = await article.render();

// Estimate reading time (~200 words per minute)
const wordCount = article.body.split(/\s+/).length;
const readingTime = `${Math.max(1, Math.ceil(wordCount / 200))} min read`;

// Format publication date
const formattedDate = new Date(article.data.pubDate).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Category slug helper
const categorySlug = article.data.category.toLowerCase().replace(/\s+/g, '-');

// Category badge color mapping
const categoryColors: Record<string, string> = {
  Virology: 'bg-indigo-50 text-indigo-800 border-indigo-200 hover:bg-indigo-100',
  Bacteriology: 'bg-emerald-50 text-emerald-800 border-emerald-200 hover:bg-emerald-100',
  Immunology: 'bg-purple-50 text-purple-800 border-purple-200 hover:bg-purple-100',
  'Antimicrobial Resistance': 'bg-amber-50 text-amber-900 border-amber-200 hover:bg-amber-100',
  'Public Health': 'bg-primary-50 text-primary-900 border-primary-200 hover:bg-primary-100',
};

const categoryStyle = categoryColors[article.data.category] || 'bg-medical-50 text-medical-900 border-medical-200';
const siteURL = Astro.site ? Astro.site.toString() : 'https://dralexvance.com';
const canonicalURL = new URL(Astro.url.pathname, siteURL).toString();

// Dynamic ScholarlyArticle / BlogPosting JSON-LD Schema
const scholarlyArticleSchema = {
  '@context': 'https://schema.org',
  '@type': 'ScholarlyArticle',
  'headline': article.data.title,
  'description': article.data.description,
  'datePublished': new Date(article.data.pubDate).toISOString(),
  'author': {
    '@type': 'Person',
    'name': article.data.author,
    'jobTitle': 'Associate Professor & Infectious Disease Specialist',
    'url': 'https://dralexvance.com',
  },
  'publisher': {
    '@type': 'Organization',
    'name': 'Dr. Alex Vance Medical Research Portal',
    'url': 'https://dralexvance.com',
  },
  'keywords': article.data.tags.join(', '),
  'articleSection': article.data.category,
  'url': canonicalURL,
  'image': article.data.heroImage ? new URL(article.data.heroImage, siteURL).toString() : undefined,
};
---

<Layout
  title={`${article.data.title} | Dr. Alex Vance Medical Articles`}
  description={article.data.description}
  activeNav="articles"
  type="article"
  articleDate={article.data.pubDate}
  image={article.data.heroImage || '/doctor_headshot.png'}
>
  <!-- ScholarlyArticle JSON-LD Schema -->
  <script type="application/ld+json" is:inline set:html={JSON.stringify(scholarlyArticleSchema)} slot="head" />

  <article class="py-12 lg:py-16 bg-white min-h-screen">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 space-y-10">
      
      <!-- Back Navigation Button -->
      <div class="flex items-center justify-between">
        <a
          href="/articles"
          class="inline-flex items-center gap-2 text-sm font-semibold text-slate-600 hover:text-medical-700 transition-colors group"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-4 h-4 text-slate-400 group-hover:text-medical-600 group-hover:-translate-x-1 transition-all"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Back to All Articles
        </a>

        <!-- RSS Link -->
        <a
          href="/rss.xml"
          target="_blank"
          class="inline-flex items-center gap-1.5 text-xs font-semibold text-amber-700 bg-amber-50 border border-amber-200 px-3 py-1 rounded-full hover:bg-amber-100 transition-colors"
        >
          <span>📡</span> RSS Feed
        </a>
      </div>

      <!-- Article Header & Metadata -->
      <header class="space-y-6 border-b border-slate-200 pb-8">
        <div class="flex flex-wrap items-center gap-3">
          <a
            href={`/articles/category/${categorySlug}`}
            class:list={['px-3 py-1 rounded-full text-xs font-bold border uppercase tracking-wider transition-colors', categoryStyle]}
          >
            {article.data.category}
          </a>
          <span class="text-xs text-slate-500 font-medium">
            {readingTime}
          </span>
        </div>

        <h1 class="font-heading font-extrabold text-3xl sm:text-4xl lg:text-5xl text-slate-900 tracking-tight leading-tight">
          {article.data.title}
        </h1>

        <p class="text-lg text-slate-600 leading-relaxed font-sans">
          {article.data.description}
        </p>

        <!-- Author & Date Bar -->
        <div class="flex items-center gap-4 pt-2">
          <div class="w-12 h-12 rounded-full bg-gradient-to-br from-primary-900 to-medical-700 flex items-center justify-center text-white font-bold text-sm shadow-md">
            AV
          </div>
          <div>
            <div class="font-bold text-slate-900 text-sm">
              {article.data.author}
            </div>
            <div class="text-xs text-slate-500">
              Published on {formattedDate}
            </div>
          </div>
        </div>
      </header>

      <!-- Optional Featured Image -->
      {article.data.heroImage && (
        <div class="rounded-2xl overflow-hidden shadow-medical-soft border border-slate-200">
          <img
            src={article.data.heroImage}
            alt={article.data.title}
            class="w-full h-auto max-h-[450px] object-cover"
          />
        </div>
      )}

      <!-- Markdown Prose Body -->
      <div class="prose prose-slate prose-lg max-w-none prose-headings:font-heading prose-headings:font-bold prose-headings:text-slate-900 prose-a:text-medical-700 prose-a:font-semibold hover:prose-a:text-medical-900 prose-blockquote:border-l-4 prose-blockquote:border-medical-500 prose-blockquote:bg-medical-50/50 prose-blockquote:p-4 prose-blockquote:rounded-r-xl prose-img:rounded-xl">
        <Content />
      </div>

      <!-- Article Tags Footnote -->
      {article.data.tags.length > 0 && (
        <div class="pt-8 border-t border-slate-200 flex flex-wrap items-center gap-2">
          <span class="text-xs font-bold text-slate-500 uppercase tracking-wider mr-2">Tags:</span>
          {article.data.tags.map((tag) => {
            const tagSlug = tag.toLowerCase().replace(/\s+/g, '-');
            return (
              <a
                href={`/articles/tag/${tagSlug}`}
                class="px-3 py-1 rounded-lg bg-slate-100 hover:bg-medical-50 hover:text-medical-800 hover:border-medical-200 border border-transparent text-slate-700 text-xs font-semibold transition-colors"
              >
                #{tag}
              </a>
            );
          })}
        </div>
      )}

      <!-- Interactive Citation Generator Component -->
      <div class="pt-6">
        <CitationGenerator
          title={article.data.title}
          author={article.data.author}
          pubDate={article.data.pubDate}
          url={canonicalURL}
        />
      </div>

      <!-- Author Bio Footer Box -->
      <div class="p-8 rounded-2xl bg-slate-50 border border-slate-200 space-y-4">
        <div class="flex items-center gap-4">
          <img
            src="/doctor_headshot.png"
            alt="Dr. Drishti Sagar"
            class="w-14 h-14 rounded-full object-cover border-2 border-medical-500"
          />
          <div>
            <h3 class="font-heading font-bold text-base text-slate-900">About the Author</h3>
            <p class="text-xs text-medical-700 font-medium">Dr. Drishti Sagar, MD • Clinical Microbiologist & Gold Medalist</p>
          </div>
        </div>
        <p class="text-xs text-slate-600 leading-relaxed">
          Dr. Drishti Sagar, MD, is a Clinical Microbiologist, MUHS MD Examination Gold Medalist (Rank 1), Infection Control Specialist, and Senior Resident with the Delhi Government. She is an active peer reviewer for IJMMTD and IJMR.
        </p>
      </div>

      <!-- Newsletter Subscriber Widget -->
      <div class="pt-8">
        <Newsletter
          title="Enjoyed this medical paper?"
          subtitle="Subscribe to receive new clinical trial reviews, viral surveillance dispatches, and public health policy updates directly."
        />
      </div>

    </div>
  </article>
</Layout>
