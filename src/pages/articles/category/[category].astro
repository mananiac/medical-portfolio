---
import { getCollection, type CollectionEntry } from 'astro:content';
import Layout from '@layouts/Layout.astro';

export async function getStaticPaths() {
  const articles = await getCollection('articles', ({ data }) => {
    return import.meta.env.PROD ? !data.draft : true;
  });

  // Extract all unique categories
  const categories = [...new Set(articles.map((article) => article.data.category))];

  return categories.map((category) => {
    const slugifiedCategory = category.toLowerCase().replace(/\s+/g, '-');
    const filteredArticles = articles.filter((article) => article.data.category === category);
    return {
      params: { category: slugifiedCategory },
      props: { categoryName: category, articles: filteredArticles },
    };
  });
}

interface Props {
  categoryName: string;
  articles: CollectionEntry<'articles'>[];
}

const { categoryName, articles } = Astro.props;

// Sort filtered articles by date descending
const sortedArticles = articles.sort(
  (a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);

const categoryColors: Record<string, string> = {
  Virology: 'bg-indigo-50 text-indigo-800 border-indigo-200',
  Bacteriology: 'bg-emerald-50 text-emerald-800 border-emerald-200',
  Immunology: 'bg-purple-50 text-purple-800 border-purple-200',
  'Antimicrobial Resistance': 'bg-amber-50 text-amber-900 border-amber-200',
  'Public Health': 'bg-primary-50 text-primary-900 border-primary-200',
};
---

<Layout title={`${categoryName} Articles | Dr. Alex Vance, MD, PhD`} activeNav="articles">
  <!-- Header -->
  <section class="py-12 bg-slate-100/70 border-b border-slate-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 space-y-4">
      <div>
        <a
          href="/articles"
          class="inline-flex items-center gap-2 text-xs font-semibold text-slate-500 hover:text-medical-700 transition-colors"
        >
          ← All Articles
        </a>
      </div>

      <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
        <div>
          <span class="text-xs font-bold text-medical-700 uppercase tracking-widest bg-medical-50 px-3 py-1 rounded-full border border-medical-200">
            Category Taxonomy
          </span>
          <h1 class="text-3xl sm:text-4xl font-extrabold text-slate-900 mt-2">
            Category: <span class="text-medical-700">{categoryName}</span>
          </h1>
          <p class="text-slate-600 text-sm mt-1">
            Showing {sortedArticles.length} article{sortedArticles.length === 1 ? '' : 's'} filed under {categoryName}.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Articles Grid -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {sortedArticles.map((article) => {
        const formattedDate = new Date(article.data.pubDate).toLocaleDateString('en-US', {
          year: 'numeric',
          month: 'short',
          day: 'numeric',
        });
        const wordCount = article.body.split(/\s+/).length;
        const readingTime = `${Math.max(1, Math.ceil(wordCount / 200))} min read`;
        const badgeStyle = categoryColors[article.data.category] || 'bg-medical-50 text-medical-800 border-medical-200';

        return (
          <article class="group bg-white rounded-2xl border border-slate-200 overflow-hidden shadow-medical-soft hover:shadow-medical-card hover:border-medical-300 transition-all duration-200 flex flex-col justify-between">
            <div>
              {article.data.heroImage && (
                <a href={`/articles/${article.slug}`} class="block overflow-hidden aspect-16/9 bg-slate-100">
                  <img
                    src={article.data.heroImage}
                    alt={article.data.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  />
                </a>
              )}

              <div class="p-6 space-y-4">
                <div class="flex items-center justify-between text-xs">
                  <span class:list={['px-2.5 py-1 rounded-full font-bold border uppercase tracking-wider', badgeStyle]}>
                    {article.data.category}
                  </span>
                  <span class="text-slate-500 font-medium">
                    {formattedDate} • {readingTime}
                  </span>
                </div>

                <h2 class="font-heading font-bold text-xl text-slate-900 group-hover:text-medical-700 transition-colors leading-snug">
                  <a href={`/articles/${article.slug}`}>
                    {article.data.title}
                  </a>
                </h2>

                <p class="text-sm text-slate-600 leading-relaxed line-clamp-3">
                  {article.data.description}
                </p>
              </div>
            </div>

            <div class="p-6 pt-0 border-t border-slate-100/80 mt-4 flex items-center justify-between">
              <span class="text-xs text-slate-500 font-medium">
                By {article.data.author}
              </span>
              <a
                href={`/articles/${article.slug}`}
                class="inline-flex items-center gap-1.5 text-xs font-bold text-medical-700 group-hover:text-medical-900 group-hover:translate-x-1 transition-all"
              >
                Read Article →
              </a>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</Layout>
