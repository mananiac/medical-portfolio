---
interface Props {
  title: string;
  author?: string;
  pubDate: Date;
  url: string;
  journal?: string;
}

const {
  title,
  author = 'Dr. Alex Vance, MD, PhD',
  pubDate,
  url,
  journal = 'Journal of Pathogen Genomics & Clinical Microbiology',
} = Astro.props;

const year = new Date(pubDate).getFullYear();
const day = new Date(pubDate).getDate();
const monthNames = ['Jan.', 'Feb.', 'Mar.', 'Apr.', 'May', 'Jun.', 'Jul.', 'Aug.', 'Sep.', 'Oct.', 'Nov.', 'Dec.'];
const monthName = monthNames[new Date(pubDate).getMonth()];

// Citations Formats
const apaCitation = `${author} (${year}). ${title}. ${journal}. ${url}`;
const mlaCitation = `${author}. "${title}." ${journal}, ${day} ${monthName} ${year}, ${url}.`;
const bibtexSlug = title.toLowerCase().replace(/[^a-z0-9]/g, '').slice(0, 20);
const bibtexCitation = `@article{vance${year}${bibtexSlug},
  author = {${author}},
  title = {${title}},
  journal = {${journal}},
  year = {${year}},
  url = {${url}}
}`;
---

<div class="bg-white rounded-2xl border border-slate-200 p-6 shadow-sm space-y-6">
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-slate-100 pb-4">
    <div class="flex items-center gap-2">
      <div class="w-8 h-8 rounded-lg bg-medical-50 text-medical-700 flex items-center justify-center font-bold text-sm">
        📚
      </div>
      <div>
        <h3 class="font-heading font-bold text-slate-900 text-base">Academic Citation Generator</h3>
        <p class="text-xs text-slate-500">Export formatted citations for academic papers & bibliographies</p>
      </div>
    </div>

    <!-- Format Tabs Selector -->
    <div class="flex bg-slate-100 p-1 rounded-xl text-xs font-semibold text-slate-600 self-start sm:self-auto">
      <button
        type="button"
        class="tab-btn px-3 py-1.5 rounded-lg transition-all bg-white text-medical-800 shadow-2xs"
        data-format="apa"
      >
        APA 7
      </button>
      <button
        type="button"
        class="tab-btn px-3 py-1.5 rounded-lg transition-all hover:text-slate-900"
        data-format="mla"
      >
        MLA 9
      </button>
      <button
        type="button"
        class="tab-btn px-3 py-1.5 rounded-lg transition-all hover:text-slate-900"
        data-format="bibtex"
      >
        BibTeX
      </button>
    </div>
  </div>

  <!-- Citation Display Boxes -->
  <div class="space-y-4">
    <!-- APA Box -->
    <div id="citation-apa" class="citation-box space-y-3">
      <div class="p-4 bg-slate-50 rounded-xl border border-slate-200 font-mono text-xs text-slate-800 leading-relaxed break-all">
        {apaCitation}
      </div>
      <button
        type="button"
        class="copy-citation-btn px-4 py-2 bg-primary-900 hover:bg-slate-800 text-white rounded-lg text-xs font-semibold shadow-2xs transition-all inline-flex items-center gap-2"
        data-citation={apaCitation}
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-medical-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
        </svg>
        <span>Copy APA Citation</span>
      </button>
    </div>

    <!-- MLA Box -->
    <div id="citation-mla" class="citation-box hidden space-y-3">
      <div class="p-4 bg-slate-50 rounded-xl border border-slate-200 font-mono text-xs text-slate-800 leading-relaxed break-all">
        {mlaCitation}
      </div>
      <button
        type="button"
        class="copy-citation-btn px-4 py-2 bg-primary-900 hover:bg-slate-800 text-white rounded-lg text-xs font-semibold shadow-2xs transition-all inline-flex items-center gap-2"
        data-citation={mlaCitation}
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-medical-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
        </svg>
        <span>Copy MLA Citation</span>
      </button>
    </div>

    <!-- BibTeX Box -->
    <div id="citation-bibtex" class="citation-box hidden space-y-3">
      <pre class="p-4 bg-slate-900 text-emerald-300 rounded-xl border border-slate-800 font-mono text-xs leading-relaxed whitespace-pre-wrap break-all">{bibtexCitation}</pre>
      <button
        type="button"
        class="copy-citation-btn px-4 py-2 bg-primary-900 hover:bg-slate-800 text-white rounded-lg text-xs font-semibold shadow-2xs transition-all inline-flex items-center gap-2"
        data-citation={bibtexCitation}
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-medical-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
        </svg>
        <span>Copy BibTeX Entry</span>
      </button>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Tab switching logic
    const tabBtns = document.querySelectorAll('.tab-btn');
    const citationBoxes = document.querySelectorAll('.citation-box');

    tabBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const format = btn.getAttribute('data-format');

        // Reset tabs styling
        tabBtns.forEach((t) => {
          t.classList.remove('bg-white', 'text-medical-800', 'shadow-2xs');
          t.classList.add('hover:text-slate-900');
        });

        // Highlight active tab
        btn.classList.add('bg-white', 'text-medical-800', 'shadow-2xs');
        btn.classList.remove('hover:text-slate-900');

        // Hide all boxes and show target
        citationBoxes.forEach((box) => box.classList.add('hidden'));
        const targetBox = document.getElementById(`citation-${format}`);
        if (targetBox) {
          targetBox.classList.remove('hidden');
        }
      });
    });

    // 1-Click Copy Citation logic
    const copyBtns = document.querySelectorAll('.copy-citation-btn');

    copyBtns.forEach((btn) => {
      btn.addEventListener('click', async () => {
        const textToCopy = btn.getAttribute('data-citation');
        if (!textToCopy) return;

        try {
          await navigator.clipboard.writeText(textToCopy);
          const spanElement = btn.querySelector('span');
          if (spanElement) {
            const originalText = spanElement.textContent;
            spanElement.textContent = 'Copied to Clipboard!';
            btn.classList.add('bg-emerald-700');

            setTimeout(() => {
              spanElement.textContent = originalText;
              btn.classList.remove('bg-emerald-700');
            }, 2500);
          }
        } catch (err) {
          console.error('Failed to copy citation: ', err);
        }
      });
    });
  });
</script>
