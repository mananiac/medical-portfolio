---
import type { NavItem } from '@/types';

interface Props {
  activeNav?: string;
}

const { activeNav = 'home' } = Astro.props;

const navItems: NavItem[] = [
  { label: 'Home', href: '/' },
  { label: 'About & CV', href: '/about' },
  { label: 'Achievements', href: '/achievements' },
  { label: 'Media Kit', href: '/media-kit' },
  { label: 'Articles', href: '/articles' },
  { label: 'Contact', href: '/contact' },
];
---

<header class="sticky top-0 z-50 glass-panel border-b border-slate-200/80 transition-all duration-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      
      <!-- Brand / Medical Title -->
      <a href="/" class="flex items-center gap-3 group">
        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-primary-900 to-medical-700 flex items-center justify-center text-white shadow-md shadow-medical-600/20 group-hover:scale-105 transition-transform duration-200 font-bold text-sm">
          DS
        </div>
        <div class="flex flex-col">
          <span class="font-heading font-bold text-lg text-slate-900 leading-tight group-hover:text-medical-700 transition-colors">
            Dr. Drishti Sagar, MD
          </span>
          <span class="text-xs text-slate-500 font-medium tracking-wide">
            Clinical Microbiologist & Infection Control Specialist
          </span>
        </div>
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex items-center gap-1" aria-label="Main Navigation">
        {navItems.map((item) => {
          const isActive = activeNav.toLowerCase() === item.label.toLowerCase();
          return (
            <a
              href={item.href}
              class:list={[
                'px-3.5 py-2 rounded-lg text-sm font-medium transition-all duration-150',
                isActive
                  ? 'text-medical-700 bg-medical-50 font-semibold border border-medical-200/60'
                  : 'text-slate-600 hover:text-slate-900 hover:bg-slate-100/80',
              ]}
              aria-current={isActive ? 'page' : undefined}
            >
              {item.label}
            </a>
          );
        })}
      </nav>

      <!-- Action CTA -->
      <div class="hidden sm:flex items-center gap-3">
        <a
          href="/contact"
          class="inline-flex items-center justify-center px-4 py-2 text-sm font-semibold text-white bg-primary-900 hover:bg-slate-800 rounded-lg shadow-sm hover:shadow-md transition-all duration-150"
        >
          Consultation
        </a>
      </div>

    </div>
  </div>
</header>
