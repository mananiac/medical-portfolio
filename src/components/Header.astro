---
import type { NavItem } from '@/types';

interface Props {
  activeNav?: string;
}

const { activeNav = 'home' } = Astro.props;

const navItems: NavItem[] = [
  { label: 'Home', href: '/' },
  { label: 'About & CV', href: '/about' },
  { label: 'Achievements', href: '/achievements' },
  { label: 'Media Kit', href: '/media-kit' },
  { label: 'Articles', href: '/articles' },
  { label: 'Contact', href: '/contact' },
];
---

<header class="sticky top-0 z-50 glass-panel border-b border-slate-200/80 transition-all duration-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      
      <!-- Brand / Medical Title -->
      <a href="/" class="flex items-center gap-3 group">
        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-primary-900 to-medical-700 flex items-center justify-center text-white shadow-md shadow-medical-600/20 group-hover:scale-105 transition-transform duration-200 font-bold text-sm">
          DS
        </div>
        <div class="flex flex-col">
          <span class="font-heading font-bold text-base sm:text-lg text-slate-900 leading-tight group-hover:text-medical-700 transition-colors">
            Dr. Drishti Sagar, MD
          </span>
          <span class="text-[11px] sm:text-xs text-slate-500 font-medium tracking-wide">
            Clinical Microbiologist & Infection Control Specialist
          </span>
        </div>
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex items-center gap-1" aria-label="Main Navigation">
        {navItems.map((item) => {
          const isActive = activeNav.toLowerCase() === item.label.toLowerCase();
          return (
            <a
              href={item.href}
              class:list={[
                'px-3.5 py-2 rounded-lg text-sm font-medium transition-all duration-150',
                isActive
                  ? 'text-medical-700 bg-medical-50 font-semibold border border-medical-200/60'
                  : 'text-slate-600 hover:text-slate-900 hover:bg-slate-100/80',
              ]}
              aria-current={isActive ? 'page' : undefined}
            >
              {item.label}
            </a>
          );
        })}
      </nav>

      <!-- Desktop Action CTA -->
      <div class="hidden sm:flex items-center gap-3">
        <a
          href="/contact"
          class="inline-flex items-center justify-center px-4 py-2 text-sm font-semibold text-white bg-primary-900 hover:bg-slate-800 rounded-lg shadow-sm hover:shadow-md transition-all duration-150"
        >
          Consultation
        </a>
      </div>

      <!-- Mobile Toggle Button -->
      <div class="flex items-center md:hidden">
        <button
          type="button"
          id="mobile-menu-btn"
          class="p-2.5 rounded-xl text-slate-600 hover:text-slate-900 hover:bg-slate-100 focus:outline-none focus:ring-2 focus:ring-medical-500 transition-colors"
          aria-controls="mobile-menu"
          aria-expanded="false"
          aria-label="Toggle navigation menu"
        >
          <!-- Hamburger Icon (visible by default) -->
          <svg
            id="hamburger-icon"
            xmlns="http://www.w3.org/2000/svg"
            class="w-6 h-6"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <!-- Close Icon (hidden by default) -->
          <svg
            id="close-icon"
            xmlns="http://www.w3.org/2000/svg"
            class="w-6 h-6 hidden"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

    </div>
  </div>

  <!-- Mobile Dropdown Menu Container -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-slate-200/80 bg-white/95 backdrop-blur-md px-4 pt-3 pb-6 space-y-2 shadow-lg">
    <nav class="flex flex-col space-y-1" aria-label="Mobile Navigation">
      {navItems.map((item) => {
        const isActive = activeNav.toLowerCase() === item.label.toLowerCase();
        return (
          <a
            href={item.href}
            class:list={[
              'mobile-nav-link px-4 py-2.5 rounded-xl text-base font-medium transition-all duration-150',
              isActive
                ? 'text-medical-700 bg-medical-50 font-semibold border border-medical-200/60'
                : 'text-slate-700 hover:text-slate-900 hover:bg-slate-100',
            ]}
            aria-current={isActive ? 'page' : undefined}
          >
            {item.label}
          </a>
        );
      })}
    </nav>
    <div class="pt-2">
      <a
        href="/contact"
        class="mobile-nav-link flex w-full items-center justify-center px-4 py-3 text-base font-semibold text-white bg-primary-900 hover:bg-slate-800 rounded-xl shadow-md transition-all duration-150"
      >
        Book Consultation
      </a>
    </div>
  </div>
</header>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const menuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const hamburgerIcon = document.getElementById('hamburger-icon');
    const closeIcon = document.getElementById('close-icon');
    const mobileLinks = document.querySelectorAll('.mobile-nav-link');

    if (menuBtn && mobileMenu && hamburgerIcon && closeIcon) {
      const toggleMenu = () => {
        const isExpanded = menuBtn.getAttribute('aria-expanded') === 'true';
        menuBtn.setAttribute('aria-expanded', String(!isExpanded));
        mobileMenu.classList.toggle('hidden');
        hamburgerIcon.classList.toggle('hidden');
        closeIcon.classList.toggle('hidden');
      };

      menuBtn.addEventListener('click', toggleMenu);

      mobileLinks.forEach((link) => {
        link.addEventListener('click', () => {
          if (!mobileMenu.classList.contains('hidden')) {
            toggleMenu();
          }
        });
      });
    }
  });
</script>
