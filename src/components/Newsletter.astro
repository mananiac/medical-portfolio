---
interface Props {
  title?: string;
  subtitle?: string;
}

const {
  title = 'Subscribe to Clinical Briefings & Research Dispatch',
  subtitle = 'Receive monthly evidence-based summaries, viral surveillance alerts, and therapeutic trial breakdowns directly in your inbox.',
} = Astro.props;
---

<div class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-primary-900 via-slate-900 to-medical-950 p-8 sm:p-12 text-white shadow-xl border border-slate-800">
  <!-- Subtle Background Pattern -->
  <div class="absolute -right-12 -top-12 w-64 h-64 bg-medical-500/10 rounded-full blur-3xl pointer-events-none"></div>

  <div class="relative z-10 max-w-3xl mx-auto text-center space-y-6">
    
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 px-3.5 py-1 rounded-full bg-medical-500/20 border border-medical-400/30 text-medical-300 text-xs font-semibold tracking-wide">
      <span>📩</span> Academic & Clinical Dispatch
    </div>

    <!-- Title & Subtitle -->
    <div class="space-y-3">
      <h2 class="font-heading font-extrabold text-2xl sm:text-3xl text-white tracking-tight leading-snug">
        {title}
      </h2>
      <p class="text-sm text-slate-300 leading-relaxed max-w-2xl mx-auto">
        {subtitle}
      </p>
    </div>

    <!-- Subscription Form Container -->
    <form
      id="newsletter-form"
      action="#"
      method="POST"
      class="max-w-md mx-auto space-y-3"
    >
      <div class="flex flex-col sm:flex-row gap-3">
        <input
          type="email"
          id="newsletter-email"
          name="email"
          required
          placeholder="Enter your institutional email..."
          class="flex-1 px-4 py-3 rounded-xl bg-white/10 border border-white/20 text-white placeholder-slate-400 text-sm focus:outline-none focus:ring-2 focus:ring-medical-400 focus:bg-white/15 transition-all"
        />
        <button
          type="submit"
          class="px-6 py-3 rounded-xl bg-medical-600 hover:bg-medical-500 text-white font-bold text-sm shadow-md hover:shadow-lg transition-all whitespace-nowrap"
        >
          Subscribe Free
        </button>
      </div>

      <!-- Trust Notice -->
      <div class="flex items-center justify-center gap-4 text-[11px] text-slate-400">
        <span>🔒 Zero Spam Guarantee</span>
        <span>•</span>
        <span>Unsubscribe Anytime</span>
        <span>•</span>
        <span>1,850+ Medical Subscribers</span>
      </div>
    </form>

    <!-- Success Message Container -->
    <div id="newsletter-success" class="hidden p-4 rounded-xl bg-emerald-500/20 border border-emerald-400/40 text-emerald-200 text-xs font-semibold max-w-md mx-auto">
      ✓ Thank you for subscribing! A confirmation link has been sent to your inbox.
    </div>

  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('newsletter-form') as HTMLFormElement | null;
    const successMsg = document.getElementById('newsletter-success');

    if (form && successMsg) {
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        form.classList.add('hidden');
        successMsg.classList.remove('hidden');
      });
    }
  });
</script>
